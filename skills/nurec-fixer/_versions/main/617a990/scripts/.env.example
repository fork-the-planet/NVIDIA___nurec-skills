#
# Copy to .env and fill in real values. NEVER commit this file with real
# tokens. Source it with `set -a && . ./.env && set +a` before running
# the workflow.

# Hugging Face token with read access to nvidia/DiffusionHarmonizer and,
# if used, nvidia/DiffusionHarmonizer-Dataset. Accept the model/dataset
# license terms in the browser before downloading gated artifacts.
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_replace_me

# Optional but commonly needed for `docker login nvcr.io` before pulling
# nvcr.io/nvidia/cosmos/cosmos-predict2-container:1.2 or images based on
# NVIDIA NGC containers. Username must be the literal string `$oauthtoken`.
# Create at: https://ngc.nvidia.com/setup/personal-keys
NGC_API_KEY=nvapi-replace-me
