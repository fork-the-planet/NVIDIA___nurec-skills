# NRE skill — required environment variables (placeholder values only).
# Copy to `.env` and replace the placeholders with your real values.

# NGC token used to `docker login nvcr.io` and to authenticate
# in-container model downloads. Generate one at:
#   https://org.ngc.nvidia.com/setup/api-key
NGC_API_KEY=nvapi-REPLACE_WITH_YOUR_KEY

# HuggingFace token (optional). Required only when downloading the
# gated nvidia/PhysicalAI-Autonomous-Vehicles-NuRec dataset or the
# nvidia/Difix3D model card. Generate at:
#   https://huggingface.co/settings/tokens
HF_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN
