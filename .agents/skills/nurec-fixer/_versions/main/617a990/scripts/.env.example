# Copy to .env and fill in real values. NEVER commit this file with real
# tokens. Source it with `set -a && . ./.env && set +a` before running
# the workflow.

# NGC personal API key — required.
#
# Used for two things:
#   1. `docker login nvcr.io` to pull `nvcr.io/nvidia/pytorch:24.10-py3`.
#      The username MUST be the literal string `$oauthtoken` and the
#      password is this key.
#   2. `ngc registry model download-version` to fetch the harmonizer
#      artifact `nvidia/nre/nurec-fixer:cosmos_3dgut_fixer_harmonizer`.
#
# Create at: https://ngc.nvidia.com/setup/personal-keys
NGC_API_KEY=nvapi-replace-me
