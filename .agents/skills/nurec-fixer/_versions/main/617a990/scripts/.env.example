# Copy to .env and fill in real values. NEVER commit this file with real
# tokens. Source it with `set -a && . ./.env && set +a` before running
# the workflow.

# HuggingFace access token — required to download the pretrained Fixer
# weights from https://huggingface.co/nvidia/Fixer
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_replace_me

# NGC API key — OPTIONAL. Only needed if your NGC account or a mirrored
# registry gates pulling nvcr.io/nvidia/cosmos/cosmos-predict2-container.
# Create at: https://ngc.nvidia.com/setup/api-keys
# Use as the password for `docker login nvcr.io` (username: $oauthtoken).
NGC_API_KEY=nvapi-replace-me
